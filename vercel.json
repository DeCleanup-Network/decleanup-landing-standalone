{
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/app.jsx", "destination": "/components/app.jsx" },
    { "source": "/community.jsx", "destination": "/components/community.jsx" },
    { "source": "/hero.jsx", "destination": "/components/hero.jsx" },
    { "source": "/primitives.jsx", "destination": "/components/primitives.jsx" },
    { "source": "/sections.jsx", "destination": "/components/sections.jsx" },
    { "source": "/tweaks-panel.jsx", "destination": "/components/tweaks-panel.jsx" },
    { "source": "/styles.css", "destination": "/stylesheets/styles.css" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/public/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(favicon|apple-touch-icon|icon-|og-image)(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=2592000" }]
    },
    {
      "source": "/(.*)\\.jsx",
      "headers": [
        { "key": "Content-Type", "value": "text/babel; charset=utf-8" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/(robots\\.txt|sitemap\\.xml|manifest\\.webmanifest)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
